# I Am An Actuary — Environment Variables
# Copy this file to .env and fill in your values

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key

# Backend
NEXT_PUBLIC_BACKEND_INTERNAL_URL=http://localhost:8000
INTERNAL_API_KEY=dev-api-key-change-in-production

# Database (not used directly — Supabase is the database)
DATABASE_URL=postgresql+asyncpg://actuary:actuary_dev@localhost:5432/iam_an_actuary

# LLM Provider (Qwen3 temporary)
LLM_PROVIDER=qwen3
QWEN3_API_KEY=your-qwen3-api-key
QWEN3_API_URL=https://api.qwen.ai/v1
QWEN3_MODEL=qwen3

# App
DEBUG=true
